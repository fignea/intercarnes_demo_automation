    {
      "parameters": {
        "language": "JavaScript",
        "jsCode": "const BASE_URL = 'https://hpkd28enkm.us-east-1.awsapprunner.com';\nconst item = $input.item.json;\nconst telefono = item.telefono || '';\nconst greeting = '¡Hola! Bienvenido a la demo de Intercarnes. Contame qué producto te interesa y en qué cantidad. Recordá que es solo una demo.';\ntry {\n  await fetch(`${BASE_URL}/api/intentions`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ intentionId: telefono, telefono })\n  });\n} catch (e) {}\nreturn [{ json: { ...item, agentReply: greeting } }];"
