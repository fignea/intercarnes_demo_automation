        "jsCode": "const trigger = $items('WhatsApp Trigger1')[0].json;\nconst ftpInfo = items[0].json;\n\nconst remotePath = ftpInfo.path || ftpInfo.remotePath || '';\nconst fileName = remotePath.split('/').pop();\nconst photoUrl = fileName ? `https://TU_FTP_PUBLIC_HOST/intercarnes/imagenes/${fileName}` : '';\n\nreturn [{\n  json: {\n    messageText: trigger.messages[0].text?.body || 'Te compartí una foto',\n    telefono: trigger.messages[0].from,\n    producto: null,\n    cantidad: null,\n    nombre: null,\n    hasPhoto: true,\n    hasAudio: false,\n    audioUrl: null,\n    photoUrl\n  }\n}];"
