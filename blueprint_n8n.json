    {
      "parameters": {
        "language": "JavaScript",
        "jsCode": "const BASE_URL = 'https://hpkd28enkm.us-east-1.awsapprunner.com';\nconst item = $input.item.json;\nconst telefono = item.telefono || '';\n\nlet hasOpenIntention = false;\nlet intention = null;\n\ntry {\n  const res = await fetch(`${BASE_URL}/api/intentions/open-by-phone/${encodeURIComponent(telefono)}`);\n  const data = await res.json();\n\n  if (data.ok && data.intention) {\n    hasOpenIntention = true;\n    intention = data.intention;\n  }\n} catch (e) {\n  // Error silencioso según tu código original\n}\n\nreturn [{\n  json: {\n    ...item,\n    hasOpenIntention,\n    intention\n  }\n}];"
      },
