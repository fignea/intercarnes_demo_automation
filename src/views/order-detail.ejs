<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Orden #<%= order.id %> - Demo Intercarnes</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
          sans-serif;
        margin: 0;
        padding: 0;
        background: #020617;
        color: #e5e7eb;
      }
      header {
        padding: 1.5rem 2rem;
        background: radial-gradient(circle at top left, #22c55e, #020617);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
      }
      h1 {
        margin: 0;
        font-size: 1.6rem;
      }
      main {
        max-width: 960px;
        margin: 2rem auto;
        padding: 0 1rem 2rem;
      }
      .card {
        background: rgba(15, 23, 42, 0.98);
        border-radius: 1.25rem;
        padding: 1.75rem;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.7);
        border: 1px solid rgba(148, 163, 184, 0.4);
      }
      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.5rem;
        font-size: 0.85rem;
        color: #9ca3af;
      }
      .badge {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        border: 1px solid rgba(34, 197, 94, 0.5);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #bbf7d0;
      }
      dl {
        display: grid;
        grid-template-columns: minmax(0, 160px) minmax(0, 1fr);
        gap: 0.5rem 1rem;
        margin: 1.5rem 0 0;
        font-size: 0.9rem;
      }
      dt {
        font-weight: 600;
        color: #9ca3af;
      }
      dd {
        margin: 0;
      }
      a {
        color: #22c55e;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .media-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.25rem;
        margin-top: 1.5rem;
      }
      .media-card {
        background: rgba(15, 23, 42, 0.9);
        border-radius: 0.75rem;
        padding: 1rem;
        border: 1px solid rgba(55, 65, 81, 0.9);
      }
      img {
        max-width: 100%;
        border-radius: 0.5rem;
        border: 1px solid rgba(31, 41, 55, 0.9);
      }
      audio {
        width: 100%;
        margin-top: 0.75rem;
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        color: #9ca3af;
      }
      .back-link span {
        font-size: 1rem;
      }
      footer {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.75rem;
        color: #6b7280;
      }
      @media (max-width: 640px) {
        dl {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <h1>Orden #<%= order.id %></h1>
      <p style="margin: 0.35rem 0 0; font-size: 0.9rem; color: #e5e7eb">
        Detalle de la orden generada vía API.
      </p>
    </header>
    <main>
      <a href="/orders" class="back-link">
        <span>←</span>
        <span>Volver al listado</span>
      </a>

      <section class="card">
        <div
          style="
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: flex-start;
          "
        >
          <div>
            <div class="badge">orden confirmada</div>
            <h2 style="margin: 0.75rem 0 0.25rem; font-size: 1.25rem">
              <%= order.producto || 'Producto no especificado' %>
            </h2>
            <p style="margin: 0; font-size: 0.9rem; color: #9ca3af">
              Intención:
              <% if (order.intention_key) { %>
              <code
                style="
                  padding: 0.15rem 0.35rem;
                  border-radius: 0.4rem;
                  background: rgba(15, 23, 42, 0.9);
                  border: 1px solid rgba(55, 65, 81, 0.9);
                  font-size: 0.75rem;
                "
                ><%= order.intention_key %></code
              >
              <% } else { %>
              <span style="color: #6b7280">creada sin intención</span>
              <% } %>
            </p>
          </div>
          <div class="meta">
            <div>
              Creada:<br />
              <strong
                ><%= order.created_at
                  ? new Date(order.created_at).toLocaleString('es-AR')
                  : '-' %></strong
              >
            </div>
            <div>
              Actualizada:<br />
              <strong
                ><%= order.updated_at
                  ? new Date(order.updated_at).toLocaleString('es-AR')
                  : '-' %></strong
              >
            </div>
          </div>
        </div>

        <dl>
          <dt>Producto</dt>
          <dd><%= order.producto || '-' %></dd>

          <dt>Cantidad</dt>
          <dd><%= order.cantidad || '-' %></dd>

          <dt>Nombre del usuario</dt>
          <dd><%= order.nombre || '-' %></dd>

          <dt>Teléfono</dt>
          <dd><%= order.telefono || '-' %></dd>
        </dl>

        <div class="media-grid">
          <div class="media-card">
            <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem">
              Foto del producto
            </h3>
            <% if (order.foto_url) { %>
            <p style="margin: 0 0 0.5rem; font-size: 0.8rem; color: #9ca3af">
              Fuente:
              <a href="<%= order.foto_url %>" target="_blank" rel="noreferrer"
                >abrir imagen</a
              >
            </p>
            <img src="<%= order.foto_url %>" alt="Foto del producto" />
            <% } else { %>
            <p style="margin: 0; font-size: 0.85rem; color: #6b7280">
              No se cargó ninguna imagen para esta orden.
            </p>
            <% } %>
          </div>

          <div class="media-card">
            <h3 style="margin: 0 0 0.5rem; font-size: 0.95rem">
              Audio de confirmación
            </h3>
            <% if (order.audio_url) { %>
            <p style="margin: 0 0 0.5rem; font-size: 0.8rem; color: #9ca3af">
              Fuente:
              <a href="<%= order.audio_url %>" target="_blank" rel="noreferrer"
                >abrir audio</a
              >
            </p>
            <audio controls>
              <source src="<%= order.audio_url %>" />
              Tu navegador no soporta el elemento de audio.
            </audio>
            <% } else { %>
            <p style="margin: 0; font-size: 0.85rem; color: #6b7280">
              No se cargó ningún audio para esta orden.
            </p>
            <% } %>
          </div>
        </div>
      </section>

      <footer>
        Demo Intercarnes · La orden se genera y confirma exclusivamente por API.
      </footer>
    </main>
  </body>
  </html>

